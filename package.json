{
  "name": "mellitrack",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"wrangler dev src/server/index.ts --local\" \"vite\"",
    "dev:local": "concurrently \"tsx scripts/local-dev.ts\" \"vite\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build && tsx scripts/inline-static.ts",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply mellitrack-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply mellitrack-db",
    "db:seed": "wrangler d1 execute mellitrack-db --local --file=./scripts/seed.sql",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.5.0",
    "date-fns": "^3.6.0",
    "hono": "^4.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@hono/node-server": "^2.0.4",
    "@playwright/test": "^1.44.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "wrangler": "^4.94.0"
  }
}
